# ROMA Framework Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Configuration (REQUIRED)
# =============================================================================
# OpenRouter provides unified access to multiple LLM providers
# Get your API key from https://openrouter.ai/

# OpenRouter API Key (REQUIRED)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model (optional, defaults to claude-3-haiku)
# Examples:
#   - openrouter/anthropic/claude-3-haiku (default - fast and cost-effective)
#   - openrouter/anthropic/claude-3-opus (most capable)
#   - openrouter/openai/gpt-4o-mini (OpenAI alternative)
#   - openrouter/openai/gpt-4o (most powerful OpenAI model)
#   - openrouter/google/gemini-pro (Google's model)
#   - openrouter/meta-llama/llama-3.1-70b-instruct (Open source option)
# See https://openrouter.ai/models for full list of available models
OPENROUTER_MODEL=openrouter/anthropic/claude-3-haiku

# =============================================================================
# E2B Configuration (OPTIONAL - only needed for Example 3)
# =============================================================================
# E2B is used for sandboxed code execution. Skip if you don't need Example 3.

# E2B API Key
# E2B_API_KEY=your_e2b_api_key_here

# E2B Template ID (optional, defaults to 'roma-dspy-sandbox')
# E2B_TEMPLATE_ID=roma-dspy-sandbox

# =============================================================================
# Storage Configuration (OPTIONAL - has defaults)
# =============================================================================
# Local file system storage path for execution artifacts
STORAGE_BASE_PATH=./storage

# =============================================================================
# Database Configuration (OPTIONAL - has defaults)
# =============================================================================
# SQLite database path for execution tracking
DATABASE_PATH=./database/roma_demo.db

# =============================================================================
# Search API Configuration (OPTIONAL)
# =============================================================================
# Search API key for custom search toolkit (if used)
# SEARCH_API_KEY=your_search_api_key_here
